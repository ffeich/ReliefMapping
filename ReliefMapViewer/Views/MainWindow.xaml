<Window x:Class="ReliefMapViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:ReliefMapViewer.Views"
        xmlns:models="clr-namespace:ReliefMapViewer.Models"
        xmlns:behaviors="clr-namespace:ReliefMapViewer.Behaviors" 
        xmlns:viewmodels="clr-namespace:ReliefMapViewer.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="{Binding FileInfo}" Height="800" Width="1000" MinHeight="650" MinWidth="850">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Content="Load Map" Command="{Binding LoadReliefMapCommand}" DockPanel.Dock="Top" Width="150" Margin="5"/>
            <CheckBox Content="Colored" VerticalAlignment="Center" IsChecked="{Binding ReliefMap.UseColor}"/>
        </StackPanel>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding CursorInfo}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding ZoomInfo}" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Name="ImageScrollViewer"
                          Grid.Column="0" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto">
                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image Name="ReliefImage" Source="{Binding ReliefMap.ReliefBitmap}" Stretch="None">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                        </Image.LayoutTransform>

                        <i:Interaction.Behaviors>
                            <behaviors:CursorMoveBehavior Command="{Binding CursorMoveCommand}"/>
                            <behaviors:RadiusAddBehavior Command="{Binding RadiusAddCommand}"/>
                            <behaviors:ZoomBehavior ZoomScale="{Binding ZoomScale, Mode=TwoWay}" ScrollViewer="{Binding ElementName=ImageScrollViewer}"/>
                            <behaviors:ZoomResetBehavior ZoomScale="{Binding ZoomScale, Mode=TwoWay}" ScrollViewer="{Binding ElementName=ImageScrollViewer}" />
                            <behaviors:PanBehavior ScrollViewer="{Binding ElementName=ImageScrollViewer}"/>
                        </i:Interaction.Behaviors>
                    </Image>

                    <Canvas Name="OverlayCanvas" IsHitTestVisible="False">
                        <ItemsControl ItemsSource="{Binding RadiusOverlay.Shapes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.Resources>
                                <DataTemplate DataType="{x:Type models:CrossShape}">
                                    <Canvas>
                                        <Line X1="{Binding X1}" Y1="{Binding CY}" X2="{Binding X2}" Y2="{Binding CY}" Stroke="{Binding Color}" StrokeThickness="1"/>
                                        <Line X1="{Binding CX}" Y1="{Binding Y1}" X2="{Binding CX}" Y2="{Binding Y2}" Stroke="{Binding Color}" StrokeThickness="1"/>
                                    </Canvas>
                                </DataTemplate>

                                <DataTemplate DataType="{x:Type models:LineShape}">
                                    <Line X1="{Binding X1}" 
                                          Y1="{Binding Y1}" 
                                          X2="{Binding X2}" 
                                          Y2="{Binding Y2}" 
                                          Stroke="{Binding Color}" 
                                          StrokeThickness="1" 
                                          StrokeDashArray="2,2"/>
                                </DataTemplate>

                                <DataTemplate DataType="{x:Type models:CircleShape}">
                                    <Canvas>
                                        <Ellipse Width="{Binding Diameter}"
                                                 Height="{Binding Diameter}"
                                                 Canvas.Left="{Binding Left}"
                                                 Canvas.Top="{Binding Top}"
                                                 Stroke="{Binding Color}"
                                                 StrokeThickness="1"/>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.Resources>
                        </ItemsControl>
                    </Canvas>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="Radius Information" FontWeight="Bold"/>
                <TextBlock Text="{Binding RadiusInfo}" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
